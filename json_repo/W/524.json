otes","ModificationVersion":"4.12","ModificationReleaseDate":"2023-06-29"},{"Type":"Modification","ModificationName":"CWE Content Team","ModificationOrganization":"MITRE","ModificationDate":"2025-12-11","ModificationComment":"updated Applicable_Platforms, Weakness_Ordinalities","ModificationVersion":"4.19","ModificationReleaseDate":"2025-12-11"},{"Type":"Modification","ModificationName":"CWE Content Team","ModificationOrganization":"MITRE","ModificationDate":"2026-04-30","ModificationComment":"updated Observed_Examples","ModificationVersion":"4.20","ModificationReleaseDate":"2026-04-30"},{"Type":"Rename","PreviousEntryName":"Information Leak Through Caching","Date":"2011-03-29"},{"Type":"Rename","PreviousEntryName":"Information Exposure Through Caching","Date":"2020-02-24"}]}